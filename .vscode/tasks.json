{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Instalar dependencias",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Backend: Ejecutar servidor Flask",
      "type": "shell",
      "command": "python app.py",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Backend: Ejecutar pruebas (unitarias + integración)",
      "type": "shell",
      "command": "python -m pytest -v",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "Backend: Ejecutar pruebas con cobertura",
      "type": "shell",
      "command": "python -m pytest --cov=. --cov-report=term-missing",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    }
  ]
}
